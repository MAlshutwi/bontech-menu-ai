# انسخ هذا الملف إلى .env واملأ القيم الحقيقية. لا تضع .env في git (محميّ بـ .gitignore).
# يُفضّل بشدة استخدام دور قاعدة بيانات READ-ONLY (انظر docs/READ_ONLY_DB_SETUP.md).

DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_readonly_user
DB_PASS=__set_in_local_env_only__

# اختياري — أمان الـ API الداخلية (إن تُركت فارغة: لا مصادقة، مع تحذير في اللوق)
API_KEY=
# اختياري — kill switch فوري بلا إعادة نشر (أي قيمة غير فارغة = تعطيل التوصيات)
AI_RECO_DISABLED=
